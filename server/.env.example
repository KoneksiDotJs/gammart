# ─── App ──────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service
DATABASE_URL="postgresql://user:password@localhost:5432/gamemarket"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your deployed Vercel frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:5173

# ─── Midtrans ─────────────────────────────────────────────────────────────────
# Get these from dashboard.midtrans.com (Sandbox) or dashboard.midtrans.com (Production)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from resend.com — free tier: 3000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxx
# Use onboarding@resend.dev for testing, your verified domain for production
EMAIL_FROM=Gammart <onboarding@resend.dev>

# ─── App URL (used in email links) ────────────────────────────────────────────
APP_URL=http://localhost:5173